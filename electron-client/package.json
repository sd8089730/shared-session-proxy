{
  "name": "720yun-shared-browser",
  "version": "1.0.0",
  "description": "720云共享浏览器 - 通过共享代理访问720yun.com",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --dir",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.720yun.shared-browser",
    "productName": "720云共享浏览器",
    "win": {
      "target": "portable",
      "icon": null
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "portable": {
      "artifactName": "${productName}.exe"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
